      "description": "卡槽要带对,每行都要一个双发了再在选卡界面开脚本,",
      "option": [
        "无"
      ]
    },
    {
      "name": "参数任务",
      "entry": "MyTask3",
      "default_check": false,
      "description": "参数任务说明文档",
      "repeatable": true,
      "repeat_count": 1,
      "option": [
        "任务选项1"
      ],
      "pipeline_override": {}
    },
    {
      "name": "带Custom的任务",
      "entry": "MyTask4",
      "default_check": false,
      "description": "带Custom的任务说明文档",
      "repeatable": true,
      "repeat_count": 1
    }
  ],
  "option": {
    "任务选项1": {
      "type": "select",
      "cases": [
        {
          "name": "文本1",
          "pipeline_override": {
            "OcrTask": {
              "text": "文本1"
            }
          }
        },
        {
          "name": "文本2",
          "pipeline_override": {
            "OcrTask": {
              "text": "文本2"
            }
          }
        }
      ]
