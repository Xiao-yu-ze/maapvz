      "name": "通用",
      "path": ["./resource"]
    }
  ],


  "task": [    {
      "name": "自动卡双赢",
      "entry": "双赢",      
      "default_check": false,
      "description": "执行这个任务的时候,其他任务不要勾选"

    },
     

    {
      "name": "地宫无尽2",
