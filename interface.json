{
  "interface_version": 2,
  "name": "Maapvz2",
  "label": "pvz2_早安",
  "version": "1.0.0",
  "icon": ".\\resource\\xyz.ico",
  "github": "https://github.com/Xiao-yu-ze/first",
  "custom_title": "Maapvz2_早安",
  "description": "这是一次伟大尝试。",
  "contact": "QQ群: 无",
  "license": "MIT",
  "welcome": "看到这段话的都是🐖",
  "mirrorchyan_rid": "项目ID",
  "mirrorchyan_multiplatform": false,
  "controller": [
    {
      "name": "安卓端",
      "type": "Adb",
      "display_short_side": 1080
    }
  ],
  "resource": [
    {
      "name": "通用",
      "path": [
        "./resource"
      ]
    }
  ],
  "task": [
    {
      "name": "自动卡双赢",
      "entry": "双赢",
      "default_check": false,
      "description": "此功能只能在mumu模拟器使用,因为要通过下拉状态栏来实现双赢,但是雷电模拟器的状态栏就是一坨,所以只能在mumu上使用."
    },
    {
      "name": "地宫无尽2",
      "entry": "地宫2",
      "default_check": false,
      "description": "卡槽要带对,每行都要一个双发了再在选卡界面开脚本,一定要有月卡"
    },
     {
      "name": "心塔自动脚本",
      "entry": "HeartTowerEntry",       
      "option": ["起始关卡选择"]        
    },
    {
      "name": "戴夫杯",
      "entry": "Dai_Enter",
      "default_check": false,
      "description": "在匹配界面开脚本"
    }

  ],

  "option": {
    "起始关卡选择": {
      "type": "select",
      "label": "起始关卡",
      "description": "选择要打的关卡",
      "default_case": "1关",
      "cases": [
        {
          "name": "1关",
          "label": "第1关",
          "pipeline_override": {
            "HeartTowerEntry": {
              "next": ["1关"]
            }
          }
        },
        {
          "name": "2关",
          "label": "第2关",
          "pipeline_override": {
            "HeartTowerEntry": {
              "next": ["2关"]
            }
          }
        },
        {
          "name": "3-149关",
          "label": "第3~149关",
          "pipeline_override": {
            "HeartTowerEntry": {
              "next": ["3_149关"]
            }
          }
        }
      ]
    }
  },

  "import": [
    "pipeline/HeartTower_0.json",
    "pipeline/HeartTower_1.json",
    "pipeline/HeartTower_2.json",
    "pipeline/HeartTower_3.json"
  ]
}
 
